<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>埼玉霊園 | 新プレート型永代供養墓【公式】</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Google Fonts: Noto Sans JP, Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700;900&family=Noto+Sans+JP:wght@300;400;500;700;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            navy: '#0F1E36',       /* 深く静謐なネイビー */
                            navyLight: '#1E3A60',  /* 明るめのネイビー */
                            gold: '#C5A880',       /* 上品なシャンパンゴールド */
                            goldDark: '#A38458',   /* 深みのあるゴールド */
                            lightGray: '#F4F5F7',  /* ベース背景用のライトグレー */
                            sand: '#EAE6DF',       /* 温かみのあるサンドベージュ */
                        }
                    },
                    fontFamily: {
                        sans: ['Noto Sans JP', 'sans-serif'],
                        serif: ['Noto Serif JP', 'serif'],
                        display: ['Playfair Display', 'serif'],
                    }
                }
            }
        }
    </script>
    <style>
        /* スムーススクロール */
        html {
            scroll-behavior: smooth;
        }
        /* 美しいグラデーションとシャドウの微調整 */
        .gold-gradient {
            background: linear-gradient(135deg, #E6D5B8 0%, #C5A880 50%, #A38458 100%);
        }
        .navy-gradient {
            background: linear-gradient(135deg, #1E3A60 0%, #0F1E36 100%);
        }
        /* フェードインアニメーション用のベーススタイル */
        .fade-in-section {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }
        .fade-in-section.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
        /* 和モダンな背景ドット装飾（ライトグレーベース） */
        .bg-pattern {
            background-color: #F4F5F7;
            background-image: radial-gradient(#E5E7EB 1px, transparent 1px);
            background-size: 24px 24px;
        }
    </style>
</head>
<body class="bg-pattern text-slate-800 font-sans antialiased selection:bg-brand-gold selection:text-white">

    <!-- フローティングコンタクト（モバイル最優先・来園促進UI） -->
    <div class="fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur shadow-2xl border-t border-brand-gold/20 md:hidden transition-all duration-300">
        <div class="grid grid-cols-3 gap-1 p-2">
            <a href="tel:048-000-0000" class="flex flex-col items-center justify-center py-2 bg-slate-100 rounded-lg text-brand-navy hover:bg-slate-200 transition-colors">
                <i data-lucide="phone" class="w-5 h-5 text-brand-gold mb-1"></i>
                <span class="text-[10px] font-bold">電話をかける</span>
            </a>
            <a href="https://maps.app.goo.gl/3M5sAYs2BSruiri56" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center py-2 bg-slate-100 rounded-lg text-brand-navy hover:bg-slate-200 transition-colors">
                <i data-lucide="map-pin" class="w-5 h-5 text-brand-gold mb-1"></i>
                <span class="text-[10px] font-bold">ルート案内</span>
            </a>
            <a href="#booking" class="flex flex-col items-center justify-center py-2 bg-gradient-to-r from-brand-navy to-brand-navyLight text-white rounded-lg hover:brightness-110 transition-all font-bold animate-pulse">
                <i data-lucide="calendar" class="w-5 h-5 text-brand-gold mb-1"></i>
                <span class="text-[10px]">現地案内会予約</span>
            </a>
        </div>
    </div>

    <!-- デスクトップ用ヘッダー -->
    <header class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-slate-200 py-3 px-4 md:px-8 transition-all">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[10px] md:text-xs text-brand-gold font-bold tracking-widest uppercase">伝統と格式を継承する埼玉の杜</span>
                <span class="text-lg md:text-xl font-serif font-bold text-brand-navy tracking-tight">埼玉霊園 <span class="text-xs md:text-sm font-sans font-normal text-slate-500 ml-1">新プレート型永代供養墓</span></span>
            </div>
            <div class="hidden lg:flex items-center space-x-6 text-sm font-medium text-slate-600">
                <a href="#features" class="hover:text-brand-gold transition-colors">7つの特徴</a>
                <a href="#plans" class="hover:text-brand-gold transition-colors">料金・プラン</a>
                <a href="#gallery" class="hover:text-brand-gold transition-colors">園内ギャラリー</a>
                <a href="#reburial" class="hover:text-brand-gold transition-colors">改葬（お墓引っ越し）</a>
                <a href="#access" class="hover:text-brand-gold transition-colors">アクセス</a>
            </div>
            <div class="flex items-center space-x-3">
                <a href="tel:048-000-0000" class="hidden sm:flex items-center space-x-2 text-brand-navy font-bold text-sm bg-slate-100 hover:bg-slate-200 py-2 px-4 rounded-full transition-colors border border-slate-300">
                    <i data-lucide="phone" class="w-4 h-4 text-brand-gold"></i>
                    <span>0480-34-7334</span>
                </a>
                <a href="#booking" class="bg-brand-navy hover:bg-brand-gold text-white text-xs md:text-sm font-bold py-2.5 px-5 rounded-full shadow-md transition-all duration-300 hover:shadow-lg">
                    現地案内会を予約
                </a>
            </div>
        </div>
    </header>

    <!-- 1. トップビジュアル (Hero Section) -->
    <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-brand-navy text-white py-16 px-4">
        <!-- 背景：ご提供いただいた広大な霊園の空撮画像 (DJI_032602.jpg) -->
        <div class="absolute inset-0 z-0">
            <img 
                src="DJI_032602.jpg" 
                alt="埼玉霊園 空撮全景" 
                class="w-full h-full object-cover opacity-60"
                onerror="this.onerror=null; this.src='https://placehold.co/1200x800/0F1E36/C5A880?text=DJI_032602.jpg';"
            >
            <!-- 視認性と静謐さを両立させる、深く洗練されたネイビーのグラデーションマスク -->
            <!-- PC環境では左の文字エリアを濃く、右の広大な敷地イメージを見せるためのグラデーション -->
            <div class="absolute inset-0 bg-gradient-to-r from-[#0F1E36] via-[#0F1E36]/75 to-transparent lg:block hidden"></div>
            <!-- モバイル環境ではテキスト全体が浮き上がるように一律にオーバーレイ -->
            <div class="absolute inset-0 bg-[#0F1E36]/80 lg:hidden block"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <!-- キャッチコピーエリア -->
            <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
                <div class="inline-flex items-center space-x-2 bg-brand-gold/20 border border-brand-gold/40 text-brand-gold px-4 py-1.5 rounded-full text-xs md:text-sm font-semibold tracking-wider uppercase mx-auto lg:mx-0">
                    <span class="w-2 h-2 rounded-full bg-brand-gold animate-ping"></span>
                    <span>待望の新設・先行受付中</span>
                </div>
                
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold tracking-loose leading-tight">
                    大切な人と、<br class="hidden md:inline">
                    制約なく美しく眠る。<br>
                    <span class="text-brand-gold text-3xl md:text-4xl lg:text-5xl block mt-4">埼玉霊園 新プレート型永代供養墓</span>
                </h1>
                
                <p class="text-slate-300 text-sm md:text-base max-w-2xl mx-auto lg:mx-0 font-light leading-relaxed">
                    国籍・宗教不問。ご夫婦、ご家族はもちろん、大切なご友人やかけがえのないパートナーともご一緒に。
                    粉骨せず、愛着のあるお骨壷のまま、いつまでも美しい緑に包まれて永代にわたり優しく供養いたします。
                </p>

                <!-- メインのアピールポイント3つ -->
                <div class="grid grid-cols-3 gap-2 sm:gap-4 max-w-md mx-auto lg:mx-0 pt-2">
                    <div class="bg-white/5 border border-white/10 p-3 rounded-xl text-center backdrop-blur-sm">
                        <div class="text-brand-gold font-bold text-xs sm:text-sm">宗教・宗派不問</div>
                        <div class="text-[10px] text-slate-400 mt-1">どなたでも可能</div>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-3 rounded-xl text-center backdrop-blur-sm">
                        <div class="text-brand-gold font-bold text-xs sm:text-sm">管理料不要</div>
                        <div class="text-[10px] text-slate-400 mt-1">将来の負担なし</div>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-3 rounded-xl text-center backdrop-blur-sm">
                        <div class="text-brand-gold font-bold text-xs sm:text-sm">承継者不要</div>
                        <div class="text-[10px] text-slate-400 mt-1">墓じまいも不要</div>
                    </div>
                </div>
            </div>

            <!-- イベント開催中のアイキャッチカード -->
            <div class="lg:col-span-5 w-full max-w-md mx-auto">
                <div class="bg-white text-slate-800 rounded-3xl p-6 md:p-8 shadow-2xl border-2 border-brand-gold relative overflow-hidden">
                    <!-- 斜めリボン -->
                    <div class="absolute top-0 right-0 bg-brand-gold text-brand-navy font-bold text-xs py-1.5 px-8 transform translate-x-6 translate-y-4 rotate-45 tracking-widest text-center shadow-md">
                        現地開催
                    </div>

                    <h2 class="text-brand-navy text-xl md:text-2xl font-serif font-bold border-b border-slate-200 pb-3 mb-4">
                        現地案内会 開催中
                    </h2>

                    <!-- 日程目立ち枠 -->
                    <div class="bg-brand-navy/5 rounded-2xl p-4 mb-4 border border-brand-navy/10">
                        <div class="text-brand-navy font-bold text-sm mb-1 flex items-center">
                            <i data-lucide="calendar" class="w-4 h-4 text-brand-gold mr-1.5"></i>
                            開催日程
                        </div>
                        <div class="text-xl md:text-2xl font-serif font-bold text-brand-navyLight tracking-wide">
                            8/1<span class="text-sm font-sans font-normal text-slate-600">（土）</span>
                            <span class="text-brand-gold">～</span> 
                            9/4<span class="text-sm font-sans font-normal text-slate-600">（金）</span>
                        </div>
                        <p class="text-[11px] text-slate-500 mt-1">※雨天実施・年中無休でご案内しております</p>
                    </div>

                    <!-- 案内詳細 -->
                    <ul class="space-y-3 text-sm text-slate-600 mb-6">
                        <li class="flex items-start">
                            <i data-lucide="clock" class="w-4.5 h-4.5 text-brand-gold mr-2 shrink-0 mt-0.5"></i>
                            <div>
                                <span class="font-bold text-slate-800">案内時間：9:00 ～ 17:00</span>
                                <p class="text-xs text-slate-500">ご都合の良い時間にお気軽にお越しください。</p>
                            </div>
                        </li>
                        <li class="flex items-start">
                            <i data-lucide="map-pin" class="w-4.5 h-4.5 text-brand-gold mr-2 shrink-0 mt-0.5"></i>
                            <div>
                                <span class="font-bold text-slate-800">受付：埼玉霊園 管理事務所</span>
                                <p class="text-xs text-slate-500">埼玉県北葛飾郡杉戸町大字本郷1775-1</p>
                            </div>
                        </li>
                    </ul>

                    <!-- 予約ボタン -->
                    <a href="#booking" class="block w-full py-4 px-6 bg-gradient-to-r from-brand-gold to-brand-goldDark hover:from-brand-goldDark hover:to-brand-gold text-white text-center font-bold rounded-xl shadow-lg transition-all duration-300 transform hover:-translate-y-0.5">
                        ご見学予約・資料請求をする
                    </a>
                    <p class="text-center text-[11px] text-slate-400 mt-2">ご予約なしの当日見学も大歓迎です</p>
                </div>
            </div>
        </div>

        <!-- 下部波形デコレーション -->
        <div class="absolute bottom-0 left-0 right-0 h-12 bg-brand-lightGray" style="clip-path: ellipse(60% 100% at 50% 100%);"></div>
    </section>

    <!-- 2. 特徴・メリット訴求 (Features Section) -->
    <section id="features" class="py-20 px-4 max-w-7xl mx-auto fade-in-section">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <span class="text-brand-gold font-bold tracking-widest text-xs uppercase block mb-2">BENEFIT & FEATURES</span>
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-brand-navy">埼玉霊園の新設永代供養墓が選ばれる「7つの理由」</h2>
            <div class="w-16 h-1 bg-brand-gold mx-auto mt-4"></div>
            <p class="text-slate-600 mt-4 text-sm md:text-base font-light">
                これまでの永代供養墓や一般墓の常識を変える、これからの時代に寄り添う新しいお墓のあり方をご提案します。
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- 特徴1 -->
            <div class="bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 relative group overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-2xl font-bold text-brand-gold group-hover:bg-brand-gold/10 transition-colors">01</div>
                <div class="w-12 h-12 rounded-2xl bg-brand-navy/5 flex items-center justify-center mb-6">
                    <i data-lucide="globe" class="w-6 h-6 text-brand-gold"></i>
                </div>
                <h3 class="text-lg font-bold text-brand-navy mb-3">宗教・宗旨・宗派不問</h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    在来仏教だけでなく、神道、キリスト教、無宗教の方など、どなたでもお求めいただけます。国籍による制限も一切ございません。
                </p>
            </div>

            <!-- 特徴2 -->
            <div class="bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 relative group overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-2xl font-bold text-brand-gold group-hover:bg-brand-gold/10 transition-colors">02</div>
                <div class="w-12 h-12 rounded-2xl bg-brand-navy/5 flex items-center justify-center mb-6">
                    <i data-lucide="coins" class="w-6 h-6 text-brand-gold"></i>
                </div>
                <h3 class="text-lg font-bold text-brand-navy mb-3">管理料・寄付金は一切不要</h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    最初にお支払いいただく永代使用料・供養料のみで、その後の年間管理料や寺院への寄付金等の追加負担は一切ありません。
                </p>
            </div>

            <!-- 特徴3 -->
            <div class="bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 relative group overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-2xl font-bold text-brand-gold group-hover:bg-brand-gold/10 transition-colors">03</div>
                <div class="w-12 h-12 rounded-2xl bg-brand-navy/5 flex items-center justify-center mb-6">
                    <i data-lucide="users" class="w-6 h-6 text-brand-gold"></i>
                </div>
                <h3 class="text-lg font-bold text-brand-navy mb-3">お墓の承継者不要</h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    お墓を引き継ぐ方がいらっしゃらない場合でも安心してご契約いただけます。墓じまいの必要や、ご家族へ負担をかける心配がありません。
                </p>
            </div>

            <!-- 特徴4 -->
            <div class="bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 relative group overflow-hidden md:col-span-2 lg:col-span-1">
                <div class="absolute top-0 right-0 w-20 h-20 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-2xl font-bold text-brand-gold group-hover:bg-brand-gold/10 transition-colors">04</div>
                <div class="w-12 h-12 rounded-2xl bg-brand-navy/5 flex items-center justify-center mb-6">
                    <i data-lucide="heart" class="w-6 h-6 text-brand-gold"></i>
                </div>
                <h3 class="text-lg font-bold text-brand-navy mb-3 flex items-center">
                    家族制限なし（親しい方と）
                    <span class="ml-2 text-xs bg-red-100 text-red-600 font-bold px-2 py-0.5 rounded-full">注目</span>
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    戸籍上の家族制限はありません。ご夫婦はもちろん、大切なご友人同士や、様々な形態のパートナーと同じお墓に眠ることができます。
                </p>
            </div>

            <!-- 特徴5 -->
            <div class="bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 relative group overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-2xl font-bold text-brand-gold group-hover:bg-brand-gold/10 transition-colors">05</div>
                <div class="w-12 h-12 rounded-2xl bg-brand-navy/5 flex items-center justify-center mb-6">
                    <i data-lucide="sparkles" class="w-6 h-6 text-brand-gold"></i>
                </div>
                <h3 class="text-lg font-bold text-brand-navy mb-3 flex items-center">
                    粉骨せず「骨壺のまま」納骨
                    <span class="ml-2 text-xs bg-green-100 text-green-700 font-bold px-2 py-0.5 rounded-full">こだわり</span>
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    他霊園に多い「粉骨して合祀」とは異なり、ご遺骨をお手元にある綺麗な骨壺の姿のままそのまま安置し、将来にわたり手厚くお守りします。
                </p>
            </div>

            <!-- 特徴6 -->
            <div class="bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 relative group overflow-hidden">
                <div class="absolute top-0 right-0 w-20 h-20 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-2xl font-bold text-brand-gold group-hover:bg-brand-gold/10 transition-colors">06</div>
                <div class="w-12 h-12 rounded-2xl bg-brand-navy/5 flex items-center justify-center mb-6">
                    <i data-lucide="shield-check" class="w-6 h-6 text-brand-gold"></i>
                </div>
                <h3 class="text-lg font-bold text-brand-navy mb-3">生前のお申し込みが可能</h3>
                <p class="text-sm text-slate-600 leading-relaxed">
                    お元気なうちに終活を進めたい方、あらかじめ自分たちの終の棲家を決めて安心したい方など、ご遺骨の有無を問わずご契約可能です。
                </p>
            </div>
        </div>

        <!-- 特徴7（永代供養付き - 横長の強調カード） -->
        <div class="mt-8 bg-brand-navy text-white rounded-3xl p-8 md:p-10 shadow-xl border-t-4 border-brand-gold relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-brand-gold/5 rounded-bl-full flex items-center justify-center font-display text-4xl font-bold text-brand-gold/20">07</div>
            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">
                <div class="lg:col-span-3 flex flex-col items-center lg:items-start text-center lg:text-left">
                    <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mb-4">
                        <i data-lucide="heart-handshake" class="w-8 h-8 text-brand-gold"></i>
                    </div>
                    <span class="text-brand-gold font-bold text-sm tracking-widest block uppercase mb-1">手厚い管理体制</span>
                    <h3 class="text-2xl font-serif font-bold text-white">永代供養付き</h3>
                </div>
                <div class="lg:col-span-9">
                    <p class="text-slate-300 text-sm md:text-base leading-relaxed text-center lg:text-left">
                        お墓をご契約いただいた後は、当霊園の運営母体である歴史ある宗教法人「馬頭院」が、手厚く永代にわたりご遺骨の供養および園内の管理・清掃をおこないます。
                        もしも無縁仏になってしまう心配がある方でも、永代にわたって手厚い法要を執り行うため、安心しておやすみいただけます。
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. 新設プレート型墓地とは？（特長深掘り＆美しいビジュアル表現） -->
    <section class="py-20 bg-brand-sand/50 border-y border-brand-gold/10 px-4">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <div class="lg:col-span-6 space-y-6">
                <span class="text-brand-gold font-bold tracking-widest text-xs uppercase block">NEW CEMETERY DESIGN</span>
                <h2 class="text-3xl md:text-4xl font-serif font-bold text-brand-navy leading-tight">
                    景観に美しく溶け込む、<br>
                    洗練されたプレート型墓碑。
                </h2>
                <div class="w-12 h-1 bg-brand-gold"></div>
                <p class="text-slate-700 text-sm md:text-base leading-relaxed font-light">
                    従来の大きく威圧感のある和型墓石とは異なり、芝生や四季折々の植栽に調和するスマートな横型「プレート墓碑」を採用。
                    自然の光をいっぱいに浴びるように設計された開放的で静謐なエリアに位置しています。
                </p>
