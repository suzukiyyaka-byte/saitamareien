                            <label class="flex items-center space-x-3 bg-white/5 rounded-xl p-3 border border-white/10 cursor-pointer select-none">
                                <input type="checkbox" id="opt-carving" onchange="calculateTotal()" class="w-4.5 h-4.5 text-brand-gold rounded border-white/20 focus:ring-brand-gold bg-transparent">
