                    <div class="space-y-4">
                        <span class="text-brand-gold font-bold text-sm tracking-widest block uppercase">埼玉霊園 / 新埼玉霊園</span>
                        <h3 class="text-xl font-serif font-bold">所在地・ご連絡先</h3>
                        <div class="h-0.5 w-10 bg-brand-gold"></div>
                        
                        <p class="text-sm text-slate-300 leading-relaxed">
                            <span class="block text-white font-bold">住所：</span>
                            〒345-0012 埼玉県北葛飾郡杉戸町大字本郷1775-1
                        </p>

                        <div class="bg-white/5 border border-white/10 rounded-2xl p-4 space-y-3">
                            <h4 class="font-bold text-sm text-brand-gold flex items-center">
                                <i data-lucide="train" class="w-4.5 h-4.5 mr-2"></i>
                                電車・徒歩でお越しの場合
                            </h4>
                            <p class="text-xs text-slate-300 leading-relaxed">
                                東武伊勢崎線（東武スカイツリーライン）「北春日部駅」より徒歩約15分（約1.2km）<br>
                                ※平坦な道のりのため、お散歩がてらお越しいただけます。
                            </p>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <a href="https://maps.app.goo.gl/3M5sAYs2BSruiri56" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center space-x-2 w-full py-4 bg-brand-gold text-brand-navy font-bold rounded-xl shadow-lg hover:bg-brand-goldDark hover:text-white transition-all transform hover:-translate-y-0.5">
                            <i data-lucide="navigation" class="w-5 h-5"></i>
                            <span>Google Mapsでルート案内を開始</span>
                        </a>
                        <p class="text-[10px] text-center text-slate-400">※スマートフォンで現在地からの経路案内をご利用いただけます</p>
                    </div>
                </div>

                <!-- Google Maps 埋め込み (IFrame) -->
                <div class="lg:col-span-7">
                    <div class="bg-white rounded-3xl p-3 shadow-2xl border border-white/10 h-full min-h-[350px] overflow-hidden relative">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1280.9322394129597!2d139.74352426649344!3d36.00204941917783!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6018b90f29b45cd9%3A0xc9d912b2d58fdc71!2z5paw5Z-8546J6ZyK5ZyS44O75Z-8546J6ZyK5ZyS!5e0!3m2!1sja!2sjp!4v1783668331644!5m2!1sja!2sjp" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 8. よくあるご質問 (FAQ Section) -->
    <section class="py-20 px-4 max-w-4xl mx-auto fade-in-section">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <span class="text-brand-gold font-bold tracking-widest text-xs uppercase block mb-2">FAQ</span>
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-brand-navy">よくあるご質問</h2>
            <div class="w-16 h-1 bg-brand-gold mx-auto mt-4"></div>
        </div>

        <div class="space-y-4">
            <!-- Q1 -->
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
                <button onclick="toggleFaq(1)" class="w-full text-left p-6 flex items-center justify-between font-bold text-slate-800 hover:bg-slate-50 transition-colors">
                    <span class="flex items-center">
                        <span class="w-7 h-7 bg-brand-navy text-white text-xs font-bold rounded-lg flex items-center justify-center mr-3 shrink-0">Q</span>
                        本当に後から追加費用（管理料など）は発生しませんか？
                    </span>
                    <i id="faq-icon-1" data-lucide="chevron-down" class="w-5 h-5 text-brand-gold transition-transform duration-300"></i>
                </button>
                <div id="faq-ans-1" class="hidden border-t border-slate-100 bg-slate-50 p-6 text-sm text-slate-600 leading-relaxed">
                    はい、発生いたしません。最初のお申し込み時にお支払いいただく料金（永代使用料・永代供養料）の中に、墓碑石、基本刻印、永代供養および清掃・維持管理がすべて含まれております。将来、ご家族へ金銭的なご負担をかけることは一切ありませんのでご安心ください。
                </div>
            </div>

            <!-- Q2 -->
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
                <button onclick="toggleFaq(2)" class="w-full text-left p-6 flex items-center justify-between font-bold text-slate-800 hover:bg-slate-50 transition-colors">
                    <span class="flex items-center">
                        <span class="w-7 h-7 bg-brand-navy text-white text-xs font-bold rounded-lg flex items-center justify-center mr-3 shrink-0">Q</span>
                        夫婦以外の、友人やパートナーとも同じお墓に入れるというのは本当ですか？
                    </span>
                    <i id="faq-icon-2" data-lucide="chevron-down" class="w-5 h-5 text-brand-gold transition-transform duration-300"></i>
                </button>
                <div id="faq-ans-2" class="hidden border-t border-slate-100 bg-slate-50 p-6 text-sm text-slate-600 leading-relaxed">
                    はい、お入りいただけます。当プレート型永代供養墓の最大の特長のひとつは「関係性の制約がない」ことです。籍を入れていないパートナー様、大切なご友人同士、お世話になった方など、従来のお墓のように戸籍や家制度にとらわれず、どなたでも一緒に永代にわたりおやすみいただけます。
                </div>
            </div>

            <!-- Q3 -->
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
                <button onclick="toggleFaq(3)" class="w-full text-left p-6 flex items-center justify-between font-bold text-slate-800 hover:bg-slate-50 transition-colors">
                    <span class="flex items-center">
                        <span class="w-7 h-7 bg-brand-navy text-white text-xs font-bold rounded-lg flex items-center justify-center mr-3 shrink-0">Q</span>
                        粉骨に抵抗があるのですが、骨壺のままで納骨できますか？
                    </span>
                    <i id="faq-icon-3" data-lucide="chevron-down" class="w-5 h-5 text-brand-gold transition-transform duration-300"></i>
                </button>
                <div id="faq-ans-3" class="hidden border-t border-slate-100 bg-slate-50 p-6 text-sm text-slate-600 leading-relaxed">
                    はい、そのままご納骨できます。一般的に合祀墓などは粉骨することが求められますが、当プレート墓地は専用の納骨区画をご用意しているため、お手元の骨壺の姿のままで大切に安置・供養いたします。ご遺骨を粉々にすることなく、故人の面影を大事にした納骨が可能です。
                </div>
            </div>

            <!-- Q4 -->
            <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
                <button onclick="toggleFaq(4)" class="w-full text-left p-6 flex items-center justify-between font-bold text-slate-800 hover:bg-slate-50 transition-colors">
                    <span class="flex items-center">
                        <span class="w-7 h-7 bg-brand-navy text-white text-xs font-bold rounded-lg flex items-center justify-center mr-3 shrink-0">Q</span>
                        生前申し込みは可能ですか？遺骨がないとダメですか？
                    </span>
                    <i id="faq-icon-4" data-lucide="chevron-down" class="w-5 h-5 text-brand-gold transition-transform duration-300"></i>
                </button>
                <div id="faq-ans-4" class="hidden border-t border-slate-100 bg-slate-50 p-6 text-sm text-slate-600 leading-relaxed">
                    もちろん生前申し込みが可能です。ご遺骨の有無を問わずご契約いただけます。最近では「子どもたちに迷惑をかけないように元気なうちに準備しておきたい」という終活の一環として、お元気なうちにお好きな区画と刻印デザインを検討して契約されるお客様が多数おられます。
                </div>
            </div>
        </div>
    </section>

    <!-- 9. 経営主体について (Organization Section) -->
    <section class="py-16 bg-slate-200/50 border-t border-slate-200 px-4">
        <div class="max-w-4xl mx-auto bg-white rounded-3xl p-8 md:p-10 shadow-lg border border-slate-200/80">
            <h2 class="text-xl md:text-2xl font-serif font-bold text-brand-navy text-center mb-6">霊園経営主体・運営</h2>
            <div class="h-0.5 w-10 bg-brand-gold mx-auto mb-8"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-sm">
                <div class="space-y-4">
                    <span class="text-brand-gold font-bold text-xs uppercase tracking-widest block">MANAGEMENT BODY</span>
                    <h3 class="font-bold text-brand-navy text-base">宗教法人 馬頭院</h3>
                    <p class="text-slate-600 leading-relaxed text-xs">
                        埼玉霊園の運営・管理および永代供養の全責任を担う伝統ある宗教法人。
                        手厚い供養体制と徹底した環境保全を常に維持し、皆様の大切なお墓を安心してお任せいただける信頼を築き上げています。
                    </p>
                </div>
                <div class="space-y-3 bg-slate-50 p-5 rounded-2xl border border-slate-100">
                    <h4 class="font-bold text-slate-700 text-xs uppercase tracking-widest">お申し込み資格</h4>
                    <p class="text-xs text-slate-600 leading-relaxed">
                        国籍、宗教、宗旨・宗派を問わず、どなたでも安心してお申し込みいただけます。<br>
                        当霊園の宗教法人が永代にわたって責任を持って管理・供養いたします。
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- 10. お問い合わせ・来園見学予約 (Booking Section) -->
    <section id="booking" class="py-24 px-4 bg-gradient-to-b from-[#182e4e] to-[#0A1424] text-white relative">
        <div class="max-w-4xl mx-auto relative z-10">
            <div class="text-center mb-12">
                <span class="text-brand-gold font-bold tracking-widest text-xs uppercase block mb-2">RESERVATION / CONTACT</span>
                <h2 class="text-3xl md:text-4xl font-serif font-bold">現地案内会予約・資料請求</h2>
                <div class="w-16 h-1 bg-brand-gold mx-auto mt-4"></div>
                <p class="text-slate-300 text-xs md:text-sm mt-4 font-light">
                    案内時間：9:00～17:00　年中無休・雨天実施。<br>
                    ご見学・ご相談のご予約、詳しい資料（無料パンフレット）のご請求はこちらから承ります。
                </p>
            </div>

            <!-- 電話受付（コンバージョン最優先） -->
            <div class="bg-white text-slate-800 rounded-3xl p-6 md:p-8 text-center shadow-2xl mb-8 border-t-4 border-brand-gold">
                <span class="text-[11px] font-bold text-brand-gold tracking-widest block uppercase mb-1">販売担当直通・お気軽にお電話ください</span>
                <div class="text-xs text-slate-500 mb-2">「ホームページの永代供養墓を見た」とお伝えいただくとスムーズです。</div>
                <a href="tel:048-000-0000" class="inline-flex items-center justify-center space-x-3 text-brand-navy hover:text-brand-gold transition-colors font-display text-3xl md:text-4xl font-black py-2 tracking-wider">
                    <i data-lucide="phone" class="w-8 h-8 text-brand-gold animate-bounce"></i>
                    <span>0480-34-7334</span>
                </a>
                <div class="text-xs text-slate-500 mt-2 font-bold">受付時間：9:00～17:00（年中無休）</div>
            </div>

            <!-- 簡単予約・お問い合わせフォーム -->
            <div class="bg-white/5 border border-white/10 backdrop-blur-md rounded-3xl p-6 md:p-10 shadow-2xl">
                <form id="contactForm" class="space-y-6" onsubmit="submitForm(event)">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- お名前 -->
                        <div>
                            <label class="block text-xs font-bold text-slate-300 tracking-wider mb-2">お名前 <span class="text-red-400">*</span></label>
                            <input type="text" required placeholder="例：山田 太郎" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all">
                        </div>
                        <!-- 電話番号 -->
                        <div>
                            <label class="block text-xs font-bold text-slate-300 tracking-wider mb-2">電話番号 <span class="text-red-400">*</span></label>
                            <input type="tel" required placeholder="例：090-0000-0000" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- メールアドレス -->
                        <div>
                            <label class="block text-xs font-bold text-slate-300 tracking-wider mb-2">メールアドレス <span class="text-red-400">*</span></label>
                            <input type="email" required placeholder="例：sample@example.com" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all">
                        </div>
                        <!-- お問い合わせ目的 -->
                        <div>
                            <label class="block text-xs font-bold text-slate-300 tracking-wider mb-2">ご希望の項目 <span class="text-red-400">*</span></label>
                            <select id="form-purpose" required class="w-full bg-slate-800 border border-white/20 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all">
                                <option value="preview" selected>現地見学・相談会を予約したい</option>
                                <option value="catalog">詳しい資料（無料パンフレット）を取り寄せたい</option>
                                <option value="reburial">お墓の引っ越し（改葬）について相談したい</option>
                                <option value="other">その他の質問</option>
                            </select>
                        </div>
                    </div>

                    <!-- お問い合わせ詳細 -->
                    <div>
                        <label class="block text-xs font-bold text-slate-300 tracking-wider mb-2">ご質問・ご要望など（任意）</label>
                        <textarea id="form-message" rows="4" placeholder="見学のご希望日時や、気になる点についてお書きください。" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-gold focus:border-transparent transition-all"></textarea>
                    </div>

                    <!-- プライバシーへの同意 -->
                    <div class="text-center">
                        <p class="text-[11px] text-slate-400 mb-4">※ご記入いただいた個人情報は、お申し込み・資料送付以外の目的で使用することはございません。</p>
                        
                        <button type="submit" class="inline-flex items-center justify-center space-x-2 px-10 py-4 bg-brand-gold hover:bg-brand-goldDark text-brand-navy font-bold rounded-xl shadow-lg transition-all transform hover:-translate-y-0.5 w-full md:w-auto">
                            <i data-lucide="send" class="w-5 h-5"></i>
                            <span>上記の内容で送信する</span>
                        </button>
                    </div>
                </form>

                <!-- 送信完了用のカスタムモーダル -->
                <div id="successModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4">
                    <div class="bg-white text-slate-800 rounded-3xl p-8 max-w-md w-full text-center space-y-4 shadow-2xl">
                        <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto">
                            <i data-lucide="check" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-xl font-bold text-brand-navy">お問い合わせを受付いたしました</h3>
                        <p class="text-xs text-slate-600 leading-relaxed">
                            この度は埼玉霊園へのお問い合わせ誠にありがとうございます。<br>
                            担当スタッフより、近日中にご案内のメールまたはお電話を差し上げます。今しばらくお待ちください。
                        </p>
                        <button onclick="closeModal()" class="w-full py-3 bg-brand-navy hover:bg-brand-gold text-white font-bold rounded-xl text-xs transition-colors">
                            閉じる
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- フッター -->
    <footer class="bg-brand-navy text-slate-400 border-t border-white/5 py-12 px-4 text-center text-xs space-y-6 pb-24 md:pb-12">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="text-center md:text-left">
                <span class="text-sm font-serif font-bold text-white block">埼玉霊園 / 新埼玉霊園</span>
                <span class="text-[10px] text-brand-gold">新プレート型永代供養墓（宗教法人 馬頭院）</span>
            </div>
            <div class="flex flex-wrap justify-center gap-4 text-[11px]">
                <a href="#features" class="hover:text-white transition-colors">特徴</a>
                <a href="#plans" class="hover:text-white transition-colors">プラン・価格</a>
                <a href="#access" class="hover:text-white transition-colors">アクセス</a>
                <a href="#booking" class="hover:text-white transition-colors">お問い合わせ</a>
            </div>
        </div>
        <div class="border-t border-white/5 pt-6 max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between text-[10px] gap-4">
            <p>&copy; 2026 埼玉霊園 プレート型永代供養墓 All Rights Reserved.</p>
            <p>※掲載されている画像やイラストは完成予想図であり、実際の植栽や石材の色調と多少異なる場合がございます。</p>
        </div>
    </footer>

    <!-- JavaScript ロジック -->
    <script>
        // Lucideアイコンの初期化
        lucide.createIcons();

        // 簡易見積もりシミュレーター用の状態管理
        let selectedPlan = 'individual'; // or 'family'
        const basePrices = {
            individual: 700000,
            family: 980000
        };

        function selectPlan(planType) {
            selectedPlan = planType;
            
            const btnIndiv = document.getElementById('btn-individual');
            const btnFam = document.getElementById('btn-family');

            if (planType === 'individual') {
                btnIndiv.classList.add('border-brand-gold', 'bg-white/10', 'text-white');
                btnIndiv.classList.remove('border-transparent', 'bg-white/5', 'text-slate-300');
                
                btnFam.classList.remove('border-brand-gold', 'bg-white/10', 'text-white');
                btnFam.classList.add('border-transparent', 'bg-white/5', 'text-slate-300');
            } else {
                btnFam.classList.add('border-brand-gold', 'bg-white/10', 'text-white');
                btnFam.classList.remove('border-transparent', 'bg-white/5', 'text-slate-300');
                
                btnIndiv.classList.remove('border-brand-gold', 'bg-white/10', 'text-white');
                btnIndiv.classList.add('border-transparent', 'bg-white/5', 'text-slate-300');
            }
            calculateTotal();
        }

        function calculateTotal() {
            let total = basePrices[selectedPlan];

            // オプション加算
            const optCarving = document.getElementById('opt-carving').checked;
            const optCeremony = document.getElementById('opt-ceremony').checked;

            if (optCarving) {
                total += 33000;
            }
            if (optCeremony) {
                total += 22000;
            }

            // 出力表示（カンマ区切りフォーマット）
            document.getElementById('sim-total-price').innerHTML = total.toLocaleString() + '<span class="text-lg text-white ml-1">円</span>';
        }

        // 見積もり連動メッセージ設定
        function setBookingMessage() {
            const planText = selectedPlan === 'individual' ? '個人墓（2人用：70万円）' : '家族墓（4人用：98万円）';
            const optCarving = document.getElementById('opt-carving').checked ? '【家名＋特製イラスト彫刻】' : '';
            const optCeremony = document.getElementById('opt-ceremony').checked ? '【個別納骨法要の代行】' : '';
            
            const messageArea = document.getElementById('form-message');
            messageArea.value = `シミュレーターで見積もりした内容についてご相談：\n希望タイプ：${planText}\n追加オプション：${optCarving} ${optCeremony}\nこちらについて現地での見学と案内を希望します。`;
            
            // 目的セレクトボックスを「見学予約」に切り替え
            document.getElementById('form-purpose').value = 'preview';
        }

        // アコーディオンFAQ
        function toggleFaq(id) {
            const ans = document.getElementById(`faq-ans-${id}`);
            const icon = document.getElementById(`faq-icon-${id}`);

            if (ans.classList.contains('hidden')) {
                ans.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                ans.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        }

        // お問い合わせ送信デモ（フォーム処理）
        function submitForm(event) {
            event.preventDefault();
            // 送信完了モーダル表示
            document.getElementById('successModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('successModal').classList.add('hidden');
            document.getElementById('contactForm').reset();
        }

        // スクロール時のフェードイン効果
        document.addEventListener("DOMContentLoaded", function() {
            const faders = document.querySelectorAll('.fade-in-section');
            
            const appearOptions = {
                threshold: 0.1,
                rootMargin: "0px 0px -50px 0px"
            };

            const appearOnScroll = new IntersectionObserver(function(entries, appearOnScroll) {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) {
                        return;
                    } else {
                        entry.target.classList.add('is-visible');
                        appearOnScroll.unobserve(entry.target);
                    }
                });
            }, appearOptions);

            faders.forEach(fader => {
                appearOnScroll.observe(fader);
            });
        });
    </script>
</body>
</html>
