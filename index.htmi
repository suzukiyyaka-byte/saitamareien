                <div class="space-y-6">
                    <!-- タイプ選択 -->
                    <div>
                        <label class="block text-xs text-brand-gold font-bold tracking-wider mb-2">1. ご希望のお墓タイプ</label>
                        <div class="grid grid-cols-2 gap-3">
